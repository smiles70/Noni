# Noni — canonical environment variable manifest
#
# This file is the source of truth for which keys exist.
# - Local dev values live in `.env` (gitignored).
# - Production values live encrypted in `infra/.env.prod.sops.yaml`.
# - Do not put real secrets in this file.
#
# Drift between this file and what each vendor holds is reported by
# `make secrets-audit` and by the `secrets-drift.yml` GitHub Action.

# ===== Application =====
PROJECT_NAME=Noni
VERSION=0.1.0
ENVIRONMENT=development                  # development | staging | production
DEBUG=false
LOG_LEVEL=INFO

# ===== Database =====
# Pooled URL used by the FastAPI app (transaction mode).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/noni
# Non-pooled URL used by Alembic and admin tooling.
DATABASE_URL_DIRECT=postgresql+psycopg2://postgres:postgres@localhost:5432/noni

# ===== Session / cryptography =====
# 32+ random bytes; rotate quarterly.
SESSION_SECRET=replace-with-256-bit-random
SESSION_COOKIE_NAME=noni_session
SESSION_TTL_DAYS=30

# ===== Auth — Clerk (ADR 0024) =====
# AUTH_PROVIDER: "mock" for dev/tests, "clerk" for staging/production.
AUTH_PROVIDER=clerk
# JWKS endpoint Clerk exposes per instance:
#   dev:  https://<frontend-api>.clerk.accounts.dev/.well-known/jwks.json
#   prod: https://clerk.<your-domain>.com/.well-known/jwks.json
CLERK_JWKS_URL=
# Same host, no /.well-known/jwks.json suffix; must match the iss claim
# on Clerk-issued JWTs.
CLERK_ISSUER=
# Optional: backend admin SDK key. Not required by the JWT verifier
# (B11 — no optional secret on success path). Set when admin endpoints
# need it.
CLERK_SECRET_KEY=
# Browser app origin for post-auth redirects.
FRONTEND_URL=https://noni-web.pages.dev

# ===== Supabase Postgres (database only; not used as auth provider) =====
# Pooled URL goes into DATABASE_URL above; non-pooled into DATABASE_URL_DIRECT.
# Keep these for `supabase db push` (RLS + pg_cron migrations).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===== CORS =====
# Comma-separated origins; must include the deployed frontend URL.
CORS_ORIGINS=https://noni-web.pages.dev

# ===== Payments — Stripe =====
# PAYMENT_PROVIDER: "mock" (no real charges) or "stripe".
# Soft-launch tip: keep mock until you're ready to take payment.
PAYMENT_PROVIDER=mock
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MODULES_4_5=
STRIPE_SUCCESS_URL=https://noni-web.pages.dev/purchase/success
STRIPE_CANCEL_URL=https://noni-web.pages.dev/purchase/cancel

# ===== Frontend (build-time; Vite inlines these) =====
VITE_API_BASE_URL=https://noni-api.fly.dev
# Must match backend AUTH_PROVIDER; checked at boot by /auth/config probe.
VITE_AUTH_PROVIDER=clerk
# Clerk publishable key (pk_live_... in production, pk_test_... for dev).
VITE_CLERK_PUBLISHABLE_KEY=

# ===== Cloudflare =====
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_R2_BUCKET=noni-backups

# ===== DB Connection Pool =====
# These tune SQLAlchemy's engine. Match to your Postgres max_connections.
# Supabase free tier ~30, pro ~60. Each Gunicorn worker gets its own pool.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=10
DB_POOL_RECYCLE=3600

# ===== Admin Accounts =====
# Comma-separated account UUIDs with admin privileges (telemetry export, etc.).
# Leave empty to disable admin endpoints.
ADMIN_ACCOUNT_IDS=

# ===== Gunicorn Workers =====
# Set per-machine via Fly [env] or docker-compose. Formula: (2 * CPU cores) + 1.
WEB_CONCURRENCY=3

# ===== Fly =====
FLY_APP_NAME=noni-api

# ===== Observability (optional at launch) =====
BETTERSTACK_SOURCE_TOKEN=
SENTRY_DSN=
