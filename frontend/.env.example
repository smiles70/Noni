# Frontend environment (Vite). Copy to `.env` and customize.
# Only variables prefixed with VITE_ are visible to client code.

# Identity provider: "mock" (default; pairs with backend MockAuthProvider)
# or "supabase" (Google OAuth via Supabase).
VITE_AUTH_PROVIDER=mock

# Supabase project URL — required when VITE_AUTH_PROVIDER=supabase.
# Find under Project Settings -> API -> Project URL.
VITE_SUPABASE_URL=
