# Noni Environment Configuration
# Copy to .env and customize for your environment.

PROJECT_NAME=Noni
VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false

# ---- Database ---------------------------------------------------------------
# Local dev (host): postgresql://postgres:postgres@localhost:5432/noni
# docker-compose:   postgresql://postgres:postgres@db:5432/noni  (overridden in compose)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/noni
# Optional: non-pooled URL for migrations. Leave empty to reuse DATABASE_URL.
DATABASE_URL_DIRECT=

# Docker Compose only (read by docker-compose.yml).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=noni

# ---- Security / sessions ----------------------------------------------------
SECRET_KEY=change-this-in-production-use-strong-random-string
SESSION_SECRET=change-me-in-production-strong-random-string
SESSION_COOKIE_NAME=noni_session
SESSION_TTL_DAYS=30

# ---- CORS -------------------------------------------------------------------
# Comma-separated origins. Empty -> dev fallback (Vite localhost:5173).
# Staging example: CORS_ORIGINS=https://staging.noni.app
# Production:     CORS_ORIGINS=https://app.noni.example,https://www.noni.example
CORS_ORIGINS=

# ---- Identity provider (Sprint B2) ------------------------------------------
# "mock" for local dev/tests; "supabase" for Google OAuth via Supabase.
# See docs/supabase-setup.md.
AUTH_PROVIDER=mock
SUPABASE_URL=
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_ISSUER=

# ---- Payment provider (Sprint B4) -------------------------------------------
# "mock" for local dev/tests; "stripe" for real checkout.
# See docs/stripe-setup.md.
PAYMENT_PROVIDER=mock
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MODULES_4_5=
STRIPE_SUCCESS_URL=http://localhost:5173/purchase/success
STRIPE_CANCEL_URL=http://localhost:5173/purchase/cancel

# ---- Account deletion (GDPR) ------------------------------------------------
DELETION_GRACE_PERIOD_DAYS=7
