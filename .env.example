# Noni Environment Configuration
# Copy to .env and customize for your environment

PROJECT_NAME=Noni
VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/noni

# Security
SECRET_KEY=change-this-in-production-use-strong-random-string

# Identity provider (Sprint B2). Use "mock" for local dev/tests; switch
# to "supabase" once SUPABASE_JWT_SECRET is set. See docs/supabase-setup.md.
AUTH_PROVIDER=mock
SUPABASE_URL=
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_ISSUER=

# Session cookie (rotate quarterly minimum).
SESSION_SECRET=change-me-in-production-strong-random-string
SESSION_COOKIE_NAME=noni_session
SESSION_TTL_DAYS=30
